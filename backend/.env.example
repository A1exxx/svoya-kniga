# Скопируйте в .env и заполните. Локально можно ничего не менять (SQLite).

# База данных. Локально — SQLite-файл. В проде — PostgreSQL (РФ-хостинг!):
# DATABASE_URL=postgresql+psycopg://svoyakniga:ПАРОЛЬ@db:5432/svoyakniga
DATABASE_URL=sqlite:///./svoyakniga.db

# Срок жизни сессии (дней)
SESSION_TTL_DAYS=14

# Cookie: в проде по HTTPS обязательно true; локально — false
COOKIE_SECURE=false
# lax — обычно; none (требует Secure=true) если фронт и API на разных доменах
COOKIE_SAMESITE=lax

# Разрешённые источники фронтенда (через запятую) — для CORS с куками
CORS_ORIGINS=http://localhost:5180,http://localhost:3000,https://a1exxx.github.io
